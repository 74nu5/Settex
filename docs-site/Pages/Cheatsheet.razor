@page "/cheatsheet"
@inherits LocalizedComponentBase
<PageTitle>@(Fr ? "Aide-mémoire — Settex" : "Cheat sheet — Settex")</PageTitle>

<h1>@(Fr ? "Aide-mémoire" : "Cheat sheet")</h1>
<p class="lead">@(Fr ? "Toutes les constructions en un coup d'œil." : "Every construct at a glance.")</p>

<table class="ref-table">
    <thead><tr><th>@(Fr ? "Construction" : "Construct")</th><th>@(Fr ? "Syntaxe" : "Syntax")</th></tr></thead>
    <tbody>
        <tr><td>@(Fr ? "Réglages de base" : "Base settings")</td><td><code>settings { Key = value }</code></td></tr>
        <tr><td>@(Fr ? "Objet imbriqué" : "Nested object")</td><td><code>Db { Host = "localhost" }</code></td></tr>
        <tr><td>@(Fr ? "Chemin pointé" : "Dot path")</td><td><code>Logging.LogLevel.Default = "Info"</code></td></tr>
        <tr><td>@(Fr ? "Tableau" : "Array")</td><td><code>Ports = [8080, 8081]</code></td></tr>
        <tr><td>@(Fr ? "Objet littéral" : "Object literal")</td><td><code>svc { Name = "auth" Port = 1 }</code></td></tr>
        <tr><td>@(Fr ? "Overlay d'environnement" : "Environment overlay")</td><td><code>env "Prod" { settings { … } }</code></td></tr>
        <tr><td>Include</td><td><code>include "./common.settex"</code></td></tr>
        <tr><td>@(Fr ? "Variable" : "Variable")</td><td><code>let host = "localhost"</code></td></tr>
        <tr><td>Interpolation</td><td><code>"${host}:${port}"</code></td></tr>
        <tr><td>@(Fr ? "Conditionnelle" : "Conditional")</td><td><code>Level = "Debug" if verbose</code></td></tr>
        <tr><td>Set-if-missing</td><td><code>Port := 8080</code></td></tr>
        <tr><td>@(Fr ? "Boucle for" : "For loop")</td><td><code>[ for x in list { item { … } } ]</code></td></tr>
        <tr><td>@(Fr ? "Commentaire" : "Comment")</td><td><code># hash</code> @(Fr ? "ou" : "or") <code>// slashes</code></td></tr>
    </tbody>
</table>

<h2>@(Fr ? "Opérateurs" : "Operators")</h2>
<table class="ref-table">
    <thead><tr><th>@(Fr ? "Groupe" : "Group")</th><th>@(Fr ? "Opérateurs" : "Operators")</th></tr></thead>
    <tbody>
        <tr><td>@(Fr ? "Arithmétiques" : "Arithmetic")</td><td><code>+</code> <code>-</code> <code>*</code> <code>/</code> (<code>+</code> @(Fr ? "concatène aussi les chaînes" : "also concatenates strings"))</td></tr>
        <tr><td>@(Fr ? "Comparaison" : "Comparison")</td><td><code>==</code> <code>!=</code> <code>&lt;</code> <code>&lt;=</code> <code>&gt;</code> <code>&gt;=</code></td></tr>
        <tr><td>@(Fr ? "Logiques" : "Logical")</td><td><code>and</code> <code>or</code> <code>not</code></td></tr>
        <tr><td>@(Fr ? "Coalescence de null" : "Null-coalescing")</td><td><code>??</code></td></tr>
        <tr><td>@(Fr ? "Groupement" : "Grouping")</td><td><code>( … )</code></td></tr>
    </tbody>
</table>

<h2>@(Fr ? "Types de valeurs" : "Value types")</h2>
<table class="ref-table">
    <thead><tr><th>@(Fr ? "Type" : "Type")</th><th>@(Fr ? "Exemple" : "Example")</th></tr></thead>
    <tbody>
        <tr><td>@(Fr ? "Chaîne" : "String")</td><td><code>@(Fr ? "\"guillemets doubles uniquement\"" : "\"double quotes only\"")</code></td></tr>
        <tr><td>@(Fr ? "Nombre" : "Number")</td><td><code>42</code>, <code>3.14</code>, <code>-10</code></td></tr>
        <tr><td>@(Fr ? "Booléen" : "Boolean")</td><td><code>true</code>, <code>false</code></td></tr>
        <tr><td>Null</td><td><code>null</code></td></tr>
        <tr><td>@(Fr ? "Tableau" : "Array")</td><td><code>[1, 2, 3]</code></td></tr>
        <tr><td>@(Fr ? "Objet" : "Object")</td><td><code>tag { … }</code> @(Fr ? "ou un bloc imbriqué" : "or a nested block")</td></tr>
    </tbody>
</table>

<div class="callout callout-note">
    @(Fr
        ? "Pièges : les noms env sont entre guillemets et englobent un bloc settings interne · les chaînes utilisent des guillemets doubles uniquement · ${…} est résolu à la compilation, pas une variable d'env runtime · les conditionnelles du bloc de base ne voient que les valeurs let globales."
        : "Gotchas: env names are quoted and wrap an inner settings block · strings use double quotes only · ${…} is compile-time, not a runtime env var · base-block conditionals only see global let values.")
</div>
