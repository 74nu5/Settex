@page "/not-found"
@layout MainLayout
@inherits LocalizedComponentBase
<PageTitle>@(Fr ? "Introuvable — Settex" : "Not found — Settex")</PageTitle>

<section class="hero">
    <div class="hero-kicker">404</div>
    @if (Fr)
    {
        <h1>Cette page a poussé l'overlay un peu trop loin.</h1>
        <p class="hero-sub">Le contenu recherché n'existe pas. Reprenons le fil.</p>
        <div class="hero-actions">
            <a class="btn btn-primary" href="">Retour à la présentation</a>
            <a class="btn btn-ghost" href="language">Guide du langage</a>
        </div>
    }
    else
    {
        <h1>This page took an overlay too far.</h1>
        <p class="hero-sub">The content you are looking for does not exist. Let's get you back on track.</p>
        <div class="hero-actions">
            <a class="btn btn-primary" href="">Back to overview</a>
            <a class="btn btn-ghost" href="language">Language guide</a>
        </div>
    }
</section>
