{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Settex",
  "scopeName": "source.settex",
  "fileTypes": ["settex"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#variables" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.settex",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.settex",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.settex",
          "match": "\\b(for|in|if)\\b"
        },
        {
          "name": "keyword.other.settex",
          "match": "\\b(settings|env|include|let)\\b"
        },
        {
          "name": "keyword.operator.logical.settex",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.settex",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.settex",
          "match": "\\bnull\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.settex",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.settex",
              "match": "\\\\[\"\\\\nrt]"
            },
            {
              "name": "meta.embedded.expression.settex",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.template-expression.begin.settex" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.template-expression.end.settex" }
              },
              "patterns": [
                { "include": "#expressions" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.settex",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.settex",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.settex",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.settex",
          "match": ":=|="
        },
        {
          "name": "keyword.operator.arithmetic.settex",
          "match": "\\+|-|\\*|/"
        },
        {
          "name": "keyword.operator.coalesce.settex",
          "match": "\\?\\?"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.settex",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.settex",
          "match": "[{}\\[\\]]"
        },
        {
          "name": "punctuation.separator.settex",
          "match": "[,.]"
        }
      ]
    },
    "expressions": {
      "patterns": [
        { "include": "#keywords" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#constants" },
        { "include": "#operators" },
        { "include": "#variables" },
        { "include": "#punctuation" }
      ]
    }
  }
}
