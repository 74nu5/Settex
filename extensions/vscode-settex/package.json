{
  "name": "settex",
  "displayName": "Settex - Configuration Language",
  "description": "Syntax highlighting, IntelliSense, and diagnostics for Settex configuration files",
  "version": "0.1.0",
  "publisher": "settex",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "settex",
    "configuration",
    "settings",
    "appsettings",
    "json"
  ],
  "activationEvents": [
    "onLanguage:settex"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "settex",
        "aliases": ["Settex", "settex"],
        "extensions": [".settex"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/file-icon.svg",
          "dark": "./images/file-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "settex",
        "scopeName": "source.settex",
        "path": "./syntaxes/settex.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "settex",
        "path": "./snippets/settex.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle-server && npm run compile",
    "bundle-server": "dotnet publish ../../src/Settex.LanguageServer/Settex.LanguageServer.csproj -c Release -o ./server --nologo",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/74nu5/Settex.git"
  },
  "homepage": "https://settex.74nu5.dev",
  "license": "MIT"
}
