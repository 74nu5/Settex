{
  "ApplicationName": "Sample Web API",
  "ApplicationVersion": "1.0.0",
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": {
        "AspNetCore": "Error",
        "Hosting": {
          "Lifetime": "Information"
        }
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_CONNECTION_STRING}",
    "CacheConnection": "${REDIS_CONNECTION_STRING}"
  },
  "JwtSettings": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "SampleWebApi",
    "Audience": "SampleWebApiClients",
    "ExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 30
  },
  "RateLimiting": {
    "Enabled": true,
    "RequestsPerMinute": 100,
    "RequestsPerHour": 5000
  },
  "Features": {
    "EnableSwagger": false,
    "EnableDetailedErrors": false,
    "EnableHealthChecks": true,
    "EnableMetrics": true
  },
  "ExternalServices": {
    "WeatherApi": {
      "BaseUrl": "https://api.weatherapi.com/v1",
      "ApiKey": "${WEATHER_API_KEY}",
      "TimeoutSeconds": 10
    },
    "EmailService": {
      "Provider": "SendGrid",
      "FromAddress": "noreply@sampleapi.com",
      "ApiKey": "${SENDGRID_API_KEY}"
    }
  }
}
