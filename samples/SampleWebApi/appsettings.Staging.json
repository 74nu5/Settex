{
  "ApplicationName": "Sample Web API",
  "ApplicationVersion": "1.0.0",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": {
        "AspNetCore": "Warning",
        "Hosting": {
          "Lifetime": "Information"
        }
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=staging-sql.example.com;Database=SampleWebApiDb;User Id=apiuser;Password=StaginPass123;Encrypt=true",
    "CacheConnection": "staging-redis.example.com:6379"
  },
  "JwtSettings": {
    "SecretKey": "${JWT_SECRET_STAGING}",
    "Issuer": "SampleWebApi",
    "Audience": "SampleWebApiClients",
    "ExpirationMinutes": 120,
    "RefreshTokenExpirationDays": 7
  },
  "RateLimiting": {
    "Enabled": true,
    "RequestsPerMinute": 200,
    "RequestsPerHour": 1000
  },
  "Features": {
    "EnableSwagger": true,
    "EnableDetailedErrors": true,
    "EnableHealthChecks": true,
    "EnableMetrics": true
  },
  "ExternalServices": {
    "WeatherApi": {
      "BaseUrl": "https://api.weatherapi.com/v1",
      "ApiKey": "dev-weather-api-key",
      "TimeoutSeconds": 30
    },
    "EmailService": {
      "Provider": "SendGrid",
      "FromAddress": "noreply@sampleapi.local",
      "ApiKey": "${SENDGRID_API_KEY_STAGING}"
    }
  }
}
