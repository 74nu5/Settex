{
  "ApplicationName": "Sample Web API",
  "ApplicationVersion": "1.0.0",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": {
        "AspNetCore": "Warning",
        "Hosting": {
          "Lifetime": "Information"
        }
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=SampleWebApiDb;Trusted_Connection=True;MultipleActiveResultSets=true",
    "CacheConnection": "localhost:6379"
  },
  "JwtSettings": {
    "SecretKey": "ThisIsADevelopmentSecretKeyDoNotUseInProduction123!",
    "Issuer": "SampleWebApi",
    "Audience": "SampleWebApiClients",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "RateLimiting": {
    "Enabled": false,
    "RequestsPerMinute": 100,
    "RequestsPerHour": 1000
  },
  "Features": {
    "EnableSwagger": true,
    "EnableDetailedErrors": true,
    "EnableHealthChecks": true,
    "EnableMetrics": false
  },
  "ExternalServices": {
    "WeatherApi": {
      "BaseUrl": "https://api.weatherapi.com/v1",
      "ApiKey": "dev-weather-api-key",
      "TimeoutSeconds": 30
    },
    "EmailService": {
      "Provider": "Console",
      "FromAddress": "noreply@sampleapi.local"
    }
  }
}
