{
  "ApplicationName": "Settex Demo",
  "ApplicationUrl": "https://localhost:8100",
  "Server": {
    "Host": "localhost",
    "Port": 443,
    "Timeout": 30,
    "MaxConnections": 1000,
    "EnableCompression": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "Database": {
    "Host": "prod-db.example.com",
    "Port": 5432,
    "Username": "admin",
    "Password": "prod_secure_password",
    "EnableSSL": true
  },
  "AllowedHosts": [
    "api.example.com",
    "www.example.com"
  ],
  "Features": [
    "logging",
    "monitoring",
    "distributed-tracing",
    "auto-scaling"
  ],
  "Services": [
    {
      "Name": "auth",
      "Url": "https://api.example.com:5001",
      "HealthCheckUrl": "https://api.example.com:5001/health",
      "HealthCheckInterval": 30,
      "EnableSSL": true,
      "Enabled": true
    },
    {
      "Name": "data",
      "Url": "https://api.example.com:5002",
      "HealthCheckUrl": "https://api.example.com:5002/health",
      "HealthCheckInterval": 30,
      "EnableSSL": true,
      "Enabled": true
    }
  ],
  "Ports": [
    {
      "Number": 8001,
      "Description": "Port 8001"
    },
    {
      "Number": 8002,
      "Description": "Port 8002"
    },
    {
      "Number": 8003,
      "Description": "Port 8003"
    }
  ],
  "DatabaseConnections": [
    {
      "Name": "primary",
      "ConnectionString": "Server=prod-db-1;Database=Main",
      "Priority": 1,
      "Enabled": true,
      "ReadOnly": false
    },
    {
      "Name": "secondary",
      "ConnectionString": "Server=prod-db-2;Database=Main",
      "Priority": 2,
      "Enabled": true,
      "ReadOnly": true
    },
    {
      "Name": "cache",
      "ConnectionString": "Server=prod-cache;Database=Cache",
      "Priority": 3,
      "Enabled": false,
      "ReadOnly": true
    }
  ],
  "Math": {
    "Addition": 15,
    "Subtraction": 12,
    "Multiplication": 20,
    "Division": 10
  },
  "Logic": {
    "And": false,
    "Or": true,
    "Not": true
  },
  "Comparison": {
    "Equal": true,
    "NotEqual": true,
    "LessThan": true,
    "GreaterThan": true,
    "LessOrEqual": true,
    "GreaterOrEqual": true
  },
  "OptionalValue": "default_value",
  "Redis": {
    "Host": "localhost",
    "Port": 6379,
    "Database": 0
  },
  "Security": {
    "RequireHttps": true,
    "EnableCORS": true
  },
  "RateLimiting": {
    "Enabled": true,
    "MaxRequests": 1000,
    "TimeWindow": 60,
    "IsStrict": true
  }
}
