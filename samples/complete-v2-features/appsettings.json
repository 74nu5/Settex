{
  "ApplicationName": "Settex Demo",
  "ApplicationUrl": "https://localhost:8100",
  "Server": {
    "Host": "localhost",
    "Port": 8100,
    "Timeout": 30,
    "MaxConnections": 100,
    "EnableCompression": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "Database": {
    "Host": "localhost",
    "Port": 5432,
    "Username": "admin",
    "Password": "default_password"
  },
  "AllowedHosts": [
    "localhost",
    "*.local",
    "localhost"
  ],
  "Features": [
    "logging",
    "monitoring"
  ],
  "Services": [
    {
      "Name": "auth",
      "Url": "http://localhost:5001",
      "Enabled": true
    },
    {
      "Name": "data",
      "Url": "http://localhost:5002",
      "Enabled": true
    }
  ],
  "Ports": [
    {
      "Number": 8001,
      "Description": "Port 8001"
    },
    {
      "Number": 8002,
      "Description": "Port 8002"
    },
    {
      "Number": 8003,
      "Description": "Port 8003"
    }
  ],
  "DatabaseConnections": [
    {
      "Name": "primary",
      "ConnectionString": "Server=localhost;Database=Main",
      "Priority": 1,
      "Enabled": true
    },
    {
      "Name": "cache",
      "ConnectionString": "Server=localhost;Database=Cache",
      "Priority": 2,
      "Enabled": false
    }
  ],
  "Math": {
    "Addition": 15,
    "Subtraction": 12,
    "Multiplication": 20,
    "Division": 10
  },
  "Logic": {
    "And": false,
    "Or": true,
    "Not": true
  },
  "Comparison": {
    "Equal": true,
    "NotEqual": true,
    "LessThan": true,
    "GreaterThan": true,
    "LessOrEqual": true,
    "GreaterOrEqual": true
  },
  "OptionalValue": "default_value",
  "Redis": {
    "Host": "localhost",
    "Port": 6379,
    "Database": 0
  }
}
