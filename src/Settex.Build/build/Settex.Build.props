<?xml version="1.0" encoding="utf-8"?>
<Project>
  <!-- 
    Settex.Build.props
    Imported early in the build process to define properties and items.
  -->
  
  <PropertyGroup>
    <!-- Default output directory for generated appsettings files -->
    <SettexOutputDirectory Condition="'$(SettexOutputDirectory)' == ''">$(MSBuildProjectDirectory)</SettexOutputDirectory>
    
    <!-- Enable/disable Settex compilation (enabled by default) -->
    <EnableSettexCompilation Condition="'$(EnableSettexCompilation)' == ''">true</EnableSettexCompilation>

    <!-- Environment files hold only their overrides (delta) by default; set true for full merged files -->
    <SettexMergeEnvironments Condition="'$(SettexMergeEnvironments)' == ''">false</SettexMergeEnvironments>

    <!-- Warn about keys set for some environments but missing from others (enabled by default) -->
    <SettexCheckCoverage Condition="'$(SettexCheckCoverage)' == ''">true</SettexCheckCoverage>
  </PropertyGroup>

  <ItemGroup>
    <!-- Auto-discover .settex files in the project directory -->
    <SettexFile Include="$(MSBuildProjectDirectory)\**\*.settex" Exclude="$(MSBuildProjectDirectory)\bin\**\*.settex;$(MSBuildProjectDirectory)\obj\**\*.settex" />
  </ItemGroup>

</Project>
